# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Git worktrees
.worktrees/

# claude code
.claude/worktrees/
.superpowers/
supabase/.temp/

# scripts — local assets and generated output (not committed)
scripts/images/
scripts/output/
scripts/procity/.venv/

# Procity sync outputs (téléchargements locaux + logs, pas à versionner)
scripts/procity/__pycache__/
scripts/procity/output_inspect/
scripts/procity/output_preview/
scripts/procity/sync_full_run.log
scripts/procity/report_run.log
scripts/procity/import_full_log*.txt
